# =============================================
# 🎮 Cracker Games BR — Configuração do Servidor
# =============================================
# COPIE este arquivo para .env e TROQUE os valores!
# cp .env.example .env
# =============================================

# Porta do servidor
PORT=3000
HOST=0.0.0.0

# JWT (JSON Web Token) — TROQUE a secret em produção!
JWT_SECRET=cracker-games-br-super-secret-key-TROQUE-ISTO-2024
JWT_EXPIRY=7d

# Chave de criptografia para o Cofre de Senhas (EXATAMENTE 32 caracteres)
ENCRYPTION_KEY=CrackerVaultKey2024SecureX32Ch!!

# Chave para criar conta admin na configuração inicial
ADMIN_SETUP_KEY=setup-cracker-admin-2024

# Sessão
SESSION_SECRET=session-secret-TROQUE-ISTO-tambem

# Ambiente (development / production)
NODE_ENV=development

# CORS — Origens permitidas (separadas por vírgula)
# Em produção, coloque o domínio real
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
